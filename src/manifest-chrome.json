{
	"name": "primedl",
	"version": "1.0.0",
	"description": "__MSG_extText__",
	"manifest_version": 3,
	"default_locale": "en",
	"permissions": [
		"clipboardWrite",
		"downloads",
		"notifications",
		"storage",
		"tabs",
		"webRequest",
		"webNavigation",
		"cookies",
		"scripting"
	],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "js/background.js",
		"type": "module"
	},
	"icons": {
		"16": "img/icon-dark-16.png",
		"48": "img/icon-dark-48.png",
		"96": "img/icon-dark-96.png"
	},
	"commands": {
		"open-popup": {
			"description": "__MSG_openPopup__"
		},
		"_execute_action": {
			"description": "__MSG_openPopup__"
		}
	},
	"options_ui": {
		"page": "options.html"
	},
	"action": {
		"default_title": "primedl",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "img/icon-dark-16.png",
			"48": "img/icon-dark-48.png"
		},
		"theme_icons": [
			{
				"dark": "img/icon-dark-96.png",
				"light": "img/icon-light-96.png",
				"size": 96
			},
			{
				"dark": "img/icon-dark-48.png",
				"light": "img/icon-light-48.png",
				"size": 48
			},
			{
				"dark": "img/icon-dark-16.png",
				"light": "img/icon-light-16.png",
				"size": 16
			}
		]
	},
	"content_scripts": [
		{
			"matches": ["*://*/*"],
			"js": ["content/keepalive.js"],
			"run_at": "document_idle"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["popup.html", "sidebar.html", "options.html"],
			"matches": ["<all_urls>"]
		}
	]
}